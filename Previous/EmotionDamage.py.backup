from json import loads
from sys import argv

reaction = {
  "ask_clarification": "Could you please clarify how you're feeling?",
  "offer_support": "I'm here to support you. Is there anything I can do to",
  "continue": "Thank you for sharing. Let's continue our conversation.",
  "slow_down": "I sense that you might be feeling overwhelmed. Let's take a moment",
  "de_escalate": "Let’s pause and try to lower the tension.",
}

actions = {
  "joy": {
    "low": "ask_clarification",
    "medium": "offer_support",
    "high":  "offer_support"
  },
  "sadness": {
    "low": "ask_clarification",
    "medium": "continue",
    "high":  "continue"
  },
  "anger": {
    "low": "ask_clarification",
    "medium": "slow_down",
    "high":  "de_escalate"
  },
  "fear": {
    "low": "ask_clarification",
    "medium": "slow_down",
    "high":  "offer_support"
  },
  "disgust": {
    "low": "ask_clarification",
    "medium": "slow_down",
    "high":  "de_escalate"
  },
  "surprise": {
    "low": "ask_clarification",
    "medium": "continue",
    "high":  "continue"
  }  
}


def main():
  if len(argv) < 2:
    print("{\"error\": \"No file input provided. Please provide a JSON file path as an argument.\"}")
    return
  
  with open(argv[1], 'r') as file:
    a = loads(file.read())
  
  emotion_type = a.get("emotion")
  confidence_level = a.get("confidence")

  if emotion_type in actions:
    a = actions[emotion_type]
    if confidence_level in a:
        print(f"{{\"action\": \"{a[confidence_level]}\", \"message\": \"{reaction[a[confidence_level]]}\"}}")
    else:
        print(f"{{ \"action\": \"ask_clarification\", \"message\": \"{reaction['ask_clarification']}\" }}")
  else:
        print(f"{{ \"action\": \"ask_clarification\", \"message\": \"{reaction['ask_clarification']}\" }}")    
if __name__ == "__main__":  main()